# Kamal 2 reads this file to resolve names listed in `env.secret:` and
# `registry.password:` in config/deploy.yml. The actual values come from
# the shell environment at deploy time — typically loaded from a gitignored
# .env file by the Makefile (see `make deploy`).
#
# This file just re-exports the named vars. Do NOT put real secrets here.

# Registry credentials
KAMAL_REGISTRY_USERNAME=$KAMAL_REGISTRY_USERNAME
KAMAL_REGISTRY_PASSWORD=$KAMAL_REGISTRY_PASSWORD

